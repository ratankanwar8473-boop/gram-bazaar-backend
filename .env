# ═══════════════════════════════════════
# Gram Bazaar – LOCAL Development (.env)
# gram_bazaar/backend/ folder mein rakho
# ═══════════════════════════════════════

PORT=5000
NODE_ENV=development

# ─── MySQL (XAMPP/WAMP) ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
# WAMP use karte ho toh bhi password khali rehta hai by default
# Agar tune MySQL mein password set kiya hai toh yahan daalo

DB_NAME=gram_bazaar

# ─── JWT ───
JWT_SECRET=gram_bazaar_local_dev_secret_key_2024
JWT_EXPIRES_IN=7d

# ─── Admin (pehli baar DB setup ke baad login) ───
ADMIN_EMAIL=admin@grambazaar.in
ADMIN_PASSWORD=Admin@123

# ─── Frontend URL (CORS) ───
FRONTEND_URL=http://localhost:3000

# ─── File Upload ───
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ─── Payment (local testing, dummy values) ───
UPI_MERCHANT_ID=grambazaar@upi
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
