# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── MySQL Database ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=gram_bazaar

# ─── JWT Secret ───
JWT_SECRET=gram_bazaar_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# ─── Admin Credentials (first time setup) ───
ADMIN_EMAIL=admin@grambazaar.in
ADMIN_PASSWORD=Admin@123

# ─── UPI / Payment ───
UPI_MERCHANT_ID=grambazaar@upi
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── File Upload ───
UPLOAD_PATH=./uploads
